{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/consulting/:path*",
      "has": [{ "type": "host", "value": "www.thegideoncorp.com" }],
      "destination": "https://advisory.thegideoncorp.com/",
      "permanent": true
    },
    {
      "source": "/consulting/:path*",
      "has": [{ "type": "host", "value": "thegideoncorp.com" }],
      "destination": "https://advisory.thegideoncorp.com/",
      "permanent": true
    },
    {
      "source": "/work/:path*",
      "has": [{ "type": "host", "value": "www.thegideoncorp.com" }],
      "destination": "https://advisory.thegideoncorp.com/work/:path*",
      "permanent": true
    },
    {
      "source": "/work/:path*",
      "has": [{ "type": "host", "value": "thegideoncorp.com" }],
      "destination": "https://advisory.thegideoncorp.com/work/:path*",
      "permanent": true
    },
    {
      "source": "/wraith/:path*",
      "has": [{ "type": "host", "value": "www.thegideoncorp.com" }],
      "destination": "https://advisory.thegideoncorp.com/wraith/:path*",
      "permanent": true
    },
    {
      "source": "/wraith/:path*",
      "has": [{ "type": "host", "value": "thegideoncorp.com" }],
      "destination": "https://advisory.thegideoncorp.com/wraith/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "advisory.thegideoncorp.com" }],
      "destination": "/consulting/index.html"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
